{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./SoT/**)",
      "Read(./secrets/**)",
      "Read(./credentials/**)",
      "Bash(cat .env*)",
      "Bash(cat */secrets/*)"
    ],
    "defaultMode": "default"
  },
  "plansDirectory": "./plans",
  "enabledMcpjsonServers": [
    "playwright"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/context-validation.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "./.claude/hooks/otel-governance-check.sh",
            "timeout": 15,
            "statusMessage": "Governance check..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/context-density-gate.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/protect-files.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "./.claude/hooks/log-hook-event.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git *)",
            "command": "./.claude/hooks/log-hook-event.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/agent-execution-logger.sh",
            "timeout": 5,
            "statusMessage": "Agent execution logging"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/sot-update-trigger.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash ./.claude/hooks/quality-gate-stop.sh",
            "timeout": 15,
            "statusMessage": "Quality gate check"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/subagent-memory-load.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/subagent-memory-save.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
